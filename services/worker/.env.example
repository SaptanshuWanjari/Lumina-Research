# Lumina Research worker service
# Copy to .env and fill secrets before running.

SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="sources"

CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

GOOGLE_API_KEY="replace-with-google-api-key"
GEMINI_EMBEDDING_MODEL="models/gemini-embedding-001"
GEMINI_EMBEDDING_DIMENSIONS=1536

WORKER_CHUNK_SIZE=900
WORKER_CHUNK_OVERLAP=120
WORKER_HTTP_TIMEOUT_SECONDS=20.0
WORKER_MAX_URL_BYTES=5000000

RUN_WORKER_LIVE_TESTS=0

# LangSmith traces worker ingestion, parsing/chunking, and embedding spans.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="replace-with-langsmith-api-key"
LANGSMITH_PROJECT="lumina-research-worker"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
