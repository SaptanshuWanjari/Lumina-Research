# Lumina Research API service
# Copy to .env and fill secrets before running.

PROJECT_NAME="Lumina Research API"
VERSION="0.1.0"
API_V1_STR="/api/v1"
API_HOST="127.0.0.1"
API_PORT=8000

SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_JWT_SECRET="replace-with-supabase-jwt-secret-at-least-32-chars"
SUPABASE_STORAGE_BUCKET="sources"

BACKEND_CORS_ORIGINS='["http://localhost:3000"]'

CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
WORKER_INGEST_TASK="worker.tasks.ingestion.process_source"
ORCHESTRATOR_RUN_TASK="orchestrator.tasks.runs.start_run"
ORCHESTRATOR_RESUME_TASK="orchestrator.tasks.runs.resume_run"

# Optional. API has no LLM calls, but keep project split if future API traces are added.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY="replace-with-langsmith-api-key"
LANGSMITH_PROJECT="lumina-research-api"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
