# Lumina Research orchestrator service
# Copy to .env and fill secrets before running.

SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Use Supabase direct/session Postgres connection string for LangGraph checkpointing.
# Example:
# postgresql://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.your-project-ref:replace-with-db-password@aws-0-region.pooler.supabase.com:5432/postgres"
LANGGRAPH_CHECKPOINT_DB_URL=""

CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

GOOGLE_API_KEY="replace-with-google-api-key"
GEMINI_PLANNER_MODEL="gemini-2.5-pro"
GEMINI_ANALYZER_MODEL="gemini-2.5-pro"
GEMINI_WRITER_MODEL="gemini-2.5-pro"
GEMINI_EMBEDDING_MODEL="models/gemini-embedding-001"
GEMINI_EMBEDDING_DIMENSIONS=1536

RETRIEVAL_MATCH_THRESHOLD=0.5
RETRIEVAL_MATCH_COUNT=8
REPORT_TITLE_PREFIX="Research Report"

ORCHESTRATOR_SUPABASE_INTEGRATION=0

# LangSmith traces Celery run wrappers, LangGraph nodes, and Gemini calls.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="replace-with-langsmith-api-key"
LANGSMITH_PROJECT="lumina-research-orchestrator"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
