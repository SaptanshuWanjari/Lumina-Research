# Compose can load a single env file from this path.
# Merge values from `services.env.example` and `website.env.example` here
# if you prefer `docker compose --env-file infra/env/.env.example ...`.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me
SUPABASE_STORAGE_BUCKET=sources

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

DATABASE_URL=postgresql://postgres:password@db.example.com:5432/postgres
LANGGRAPH_CHECKPOINT_DB_URL=

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SERVICES_API_BASE_URL=http://api:8000

GOOGLE_API_KEY=replace-me
AI_SETTINGS_ENCRYPTION_KEY=replace-me-with-32-plus-bytes
OLLAMA_BASE_URL=http://host.docker.internal:11434

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
WORKER_LANGSMITH_PROJECT=lumina-research-worker
ORCHESTRATOR_LANGSMITH_PROJECT=lumina-research-orchestrator
