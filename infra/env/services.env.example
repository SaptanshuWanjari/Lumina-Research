# Shared service settings for docker compose.
# Copy to a real env file or export these variables before `docker compose up`.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me
SUPABASE_STORAGE_BUCKET=sources

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DATABASE_URL=postgresql://postgres:password@db.example.com:5432/postgres
LANGGRAPH_CHECKPOINT_DB_URL=

GOOGLE_API_KEY=replace-me
AI_SETTINGS_ENCRYPTION_KEY=replace-me-with-32-plus-bytes
OLLAMA_BASE_URL=http://host.docker.internal:11434

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
WORKER_LANGSMITH_PROJECT=lumina-research-worker
ORCHESTRATOR_LANGSMITH_PROJECT=lumina-research-orchestrator
