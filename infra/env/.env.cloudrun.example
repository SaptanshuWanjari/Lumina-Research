# Google Cloud Run Environment Configuration

# ============= API Service =============
# Copy to services/api/.env

API_HOST=0.0.0.0
API_PORT=8080

# Celery/Queue Configuration
# Cloud Run doesn't have direct Redis access in free tier
# Use Cloud Tasks for job queue instead
CELERY_BROKER_URL=cloud-tasks://projects/YOUR_PROJECT_ID/locations/us-central1
CELERY_RESULT_BACKEND=cloud-firestore://

# Database & Authentication
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<get-from-supabase-dashboard>
SUPABASE_JWT_SECRET=<get-from-supabase-dashboard>
SUPABASE_STORAGE_BUCKET=sources

# CORS for Vercel frontend
BACKEND_CORS_ORIGINS=["https://your-vercel-domain.vercel.app","https://your-custom-domain.com"]

# ============= Worker Service =============
# Copy to services/worker/.env

CELERY_BROKER_URL=cloud-tasks://projects/YOUR_PROJECT_ID/locations/us-central1
CELERY_RESULT_BACKEND=cloud-firestore://

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<get-from-supabase-dashboard>
SUPABASE_STORAGE_BUCKET=sources

# AI/ML Configuration
GOOGLE_API_KEY=<get-from-google-cloud-console>
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=1536

# Monitoring (Optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<optional>
LANGSMITH_PROJECT=lumina-research-worker
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============= Orchestrator Service =============
# Copy to services/orchestrator/.env

CELERY_BROKER_URL=cloud-tasks://projects/YOUR_PROJECT_ID/locations/us-central1
CELERY_RESULT_BACKEND=cloud-firestore://

# Database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<get-from-supabase-dashboard>
DATABASE_URL=postgresql://user:password@your-db:5432/postgres
LANGGRAPH_CHECKPOINT_DB_URL=postgresql://user:password@your-db:5432/langgraph

# Encryption
AI_SETTINGS_ENCRYPTION_KEY=<generate-with-openssl-rand-32>

# LLM Configuration
GOOGLE_API_KEY=<get-from-google-cloud-console>
GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
GEMINI_ANALYZER_MODEL=gemini-2.5-flash-lite
GEMINI_WRITER_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=1536

# Ollama (for local model inference - optional)
OLLAMA_BASE_URL=http://localhost:11434

# Monitoring
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<optional>
LANGSMITH_PROJECT=lumina-research-orchestrator
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============= Website (Already on Vercel) =============
# These should be in Vercel environment variables

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<get-from-supabase-dashboard>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Points to Cloud Run API service
SERVICES_API_BASE_URL=https://lumina-api-xxx.run.app

# Site URLs
SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Encryption key (must match orchestrator)
AI_SETTINGS_ENCRYPTION_KEY=<same-as-orchestrator>

# ============= Setup Instructions =============
#
# 1. Replace YOUR_PROJECT_ID with your GCP project ID
# 2. Generate encryption key:
#    openssl rand -base64 32
#
# 3. Get secrets from Supabase dashboard:
#    - Go to project settings → API keys
#    - Copy SUPABASE_URL
#    - Copy Service Role key (SUPABASE_SERVICE_ROLE_KEY)
#    - Copy JWT secret (SUPABASE_JWT_SECRET)
#    - Copy anon/public key (NEXT_PUBLIC_SUPABASE_ANON_KEY)
#
# 4. Get Google API key:
#    - Go to Google Cloud Console
#    - Create API key for Gemini API
#    - Enable required APIs:
#      * Vertex AI API
#      * Google Generative AI API
#
# 5. Create secrets in Google Secret Manager:
#    gcloud secrets create SUPABASE_URL --data-file=<(echo -n "...")
#    gcloud secrets create SUPABASE_SERVICE_ROLE_KEY --data-file=<(echo -n "...")
#    gcloud secrets create GOOGLE_API_KEY --data-file=<(echo -n "...")
#    etc.
#
# 6. Update Cloud Run services with secrets:
#    gcloud run services update lumina-api \
#      --set-secrets=SUPABASE_URL=SUPABASE_URL:latest,GOOGLE_API_KEY=GOOGLE_API_KEY:latest
#
# 7. Update Vercel environment variables in dashboard
